# Text files — normalise line endings to LF
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.json   text eol=lf
*.py     text eol=lf
*.sh     text eol=lf
*.cfg    text eol=lf
*.txt    text eol=lf

# Binary files — never modify line endings or diff as text
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.zip    binary
*.gz     binary
